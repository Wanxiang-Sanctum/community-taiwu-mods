<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="taiwu-modkit" value="https://nuget.pkg.github.com/Wanxiang-Sanctum/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <taiwu-modkit>
      <add key="Username" value="%TAIWU_MODKIT_GITHUB_USER%" />
      <add key="ClearTextPassword" value="%TAIWU_MODKIT_GITHUB_TOKEN%" />
      <add key="ValidAuthenticationTypes" value="Basic" />
    </taiwu-modkit>
  </packageSourceCredentials>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="taiwu-modkit">
      <package pattern="Taiwu.ModKit.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
