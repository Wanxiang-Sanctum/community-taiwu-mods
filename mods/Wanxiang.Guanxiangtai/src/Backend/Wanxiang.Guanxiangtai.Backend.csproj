<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference
      Include="$(TaiwuModsSharedDir)Wanxiang.Taiwu.Logging/Wanxiang.Taiwu.Logging.csproj"
    />
    <ProjectReference
      Include="$(TaiwuModsModsDir)Wanxiang.Guanxiangtai/src/Ipc/Wanxiang.Guanxiangtai.Ipc.csproj"
    />
  </ItemGroup>

  <!-- Runtime DLLs are provided by Wanxiang.Prelude.Backend; this project only needs compile assets. -->
  <ItemGroup>
    <PackageReference
      Include="MessagePack"
      ExcludeAssets="runtime"
      PrivateAssets="all"
    />
    <PackageReference
      Include="MessagePipe"
      ExcludeAssets="runtime"
      PrivateAssets="all"
    />
    <PackageReference
      Include="MessagePipe.Interprocess"
      ExcludeAssets="runtime"
      PrivateAssets="all"
    />
    <PackageReference
      Include="Microsoft.Extensions.DependencyInjection"
      ExcludeAssets="runtime"
      PrivateAssets="all"
    />
    <PackageReference
      Include="Taiwu.ModKit.References.Backend"
      PrivateAssets="all"
    />
  </ItemGroup>
</Project>
