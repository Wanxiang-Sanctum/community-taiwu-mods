    <TaiwuModCopyDependency Include="UniTask.dll" />
    <TaiwuModCopyDependency Include="UniTask.Linq.dll" />
    <TaiwuModCopyDependency Include="UniTask.TextMeshPro.dll" />
    <TaiwuModCopyDependency Include="UniTask.Addressables.dll" />
    <TaiwuModCopyDependency Include="VContainer.dll" />
  </ItemGroup>

