<Project>
  <PropertyGroup>
    <TaiwuModSide>Backend</TaiwuModSide>
    <TaiwuModPluginPackageDirectory
    >Plugins/Backend</TaiwuModPluginPackageDirectory>
    <TaiwuModCopyDependencyPackageDirectory
    >Plugins/Backend</TaiwuModCopyDependencyPackageDirectory>
    <UsePublicizer>false</UsePublicizer>
  </PropertyGroup>

  <ItemGroup>
    <TaiwuModMergeDependency Include="Wanxiang.Prelude.PluginLoading.dll" />
    <TaiwuModCopyDependency Include="MessagePack.Annotations.dll" />
    <TaiwuModCopyDependency Include="MessagePack.dll" />
    <TaiwuModCopyDependency Include="MessagePipe.dll" />
    <TaiwuModCopyDependency Include="MessagePipe.Interprocess.dll" />
    <TaiwuModCopyDependency Include="Microsoft.CodeAnalysis.dll" />
    <TaiwuModCopyDependency Include="Microsoft.CodeAnalysis.CSharp.dll" />
    <TaiwuModCopyDependency
      Include="Microsoft.Extensions.DependencyInjection.dll"
    />
    <TaiwuModCopyDependency
      Include="Microsoft.Extensions.DependencyInjection.Abstractions.dll"
    />
    <TaiwuModCopyDependency Include="Microsoft.NET.StringTools.dll" />
    <TaiwuModCopyDependency Include="System.IO.Pipelines.dll" />
  </ItemGroup>

  <!--
  <ItemGroup>
    <Publicize
      Include="GameData"
      IncludeCompilerGeneratedMembers="false"
      IncludeVirtualMembers="false"
    />
  </ItemGroup>
  -->
</Project>
