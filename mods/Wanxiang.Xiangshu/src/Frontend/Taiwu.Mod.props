<Project>
  <PropertyGroup>
    <TaiwuModSide>Frontend</TaiwuModSide>
    <TaiwuModPluginSubdirectory>Frontend</TaiwuModPluginSubdirectory>
  </PropertyGroup>

  <ItemGroup>
    <TaiwuModCopyDependency Include="Wanxiang.Xiangshu.Ipc.dll" />
    <TaiwuModCopyDependency
      Include="Wanxiang.Xiangshu.Scripting.Contracts.dll"
    />
    <TaiwuModMergeDependency Include="Wanxiang.Xiangshu.Scripting.dll" />
  </ItemGroup>

  <ItemGroup>
    <Publicize
      Include="Assembly-CSharp"
      IncludeCompilerGeneratedMembers="false"
      IncludeVirtualMembers="false"
      MemberPattern="^(Game\.Views\.MouseTips\.AiActionAreaNormal\..*|Game\.Views\.CharacterMenu\..*|UIElement\..*|CScrollbarLegacy\..*)$"
    />
  </ItemGroup>

  <!--
  <ItemGroup>
    <Publicize
      Include="Assembly-CSharp"
      IncludeCompilerGeneratedMembers="false"
      IncludeVirtualMembers="false"
    />
  </ItemGroup>
  -->
</Project>
