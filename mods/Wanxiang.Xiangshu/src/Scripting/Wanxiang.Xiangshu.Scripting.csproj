<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net8.0</TargetFrameworks>
    <TaiwuModCompatibilityProfile>GameRuntime</TaiwuModCompatibilityProfile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference
      Include="$(TaiwuModsModsDir)Wanxiang.Xiangshu/src/Ipc/Wanxiang.Xiangshu.Ipc.csproj"
    />
  </ItemGroup>

  <!-- Wanxiang.Prelude provides the Roslyn runtime DLLs for both frontend and backend. -->
  <ItemGroup>
    <PackageReference
      Include="Microsoft.CodeAnalysis.CSharp"
      ExcludeAssets="runtime"
    />
  </ItemGroup>

  <ItemGroup>
    <PackageReference
      Include="Taiwu.ModKit.References.Shared"
      PrivateAssets="all"
    />
  </ItemGroup>
</Project>
