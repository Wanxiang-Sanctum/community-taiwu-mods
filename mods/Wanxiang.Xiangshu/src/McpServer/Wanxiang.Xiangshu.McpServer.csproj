<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <UseAppHost>true</UseAppHost>
    <TaiwuModPublishPackagePath
    >Processes/Wanxiang.Xiangshu.McpServer</TaiwuModPublishPackagePath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference
      Include="$(TaiwuModsModsDir)Wanxiang.Xiangshu/src/Ipc/Wanxiang.Xiangshu.Ipc.csproj"
    />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MessagePipe" />
    <PackageReference Include="MessagePipe.Interprocess" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
    <PackageReference Include="Newtonsoft.Json" />
  </ItemGroup>

  <Import
    Project="$(TaiwuModsModsDir)Taiwu.Mod.PublishDirectory.Pack.targets"
  />
</Project>
