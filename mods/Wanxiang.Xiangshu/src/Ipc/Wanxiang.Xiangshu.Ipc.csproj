<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net8.0;net10.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup
    Condition="'$(TargetFramework)' == 'netstandard2.1' Or '$(TargetFramework)' == 'net8.0'"
  >
    <PackageReference
      Include="Taiwu.ModKit.References.Shared"
      PrivateAssets="all"
    />
  </ItemGroup>

  <ItemGroup>
    <PackageReference
      Include="MessagePack"
      ExcludeAssets="runtime"
      PrivateAssets="all"
    />
  </ItemGroup>
</Project>
